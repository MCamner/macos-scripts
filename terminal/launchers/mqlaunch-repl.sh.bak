#!/usr/bin/env bash

set -uo pipefail

BASE_DIR="${BASE_DIR:-$HOME/macos-scripts}"
MQ_SHELL="${SHELL:-/bin/zsh}"
MQ_LINE="════════════════════════════════════════════════════"
PROMPT_LABEL="mqlaunch > "

run_doctor() {
  "$BASE_DIR/tools/scripts/doctor.sh"
}

run_perf() {
  "$BASE_DIR/terminal/bridges/performance-bridge.sh"
}

run_dev() {
  "$BASE_DIR/terminal/bridges/dev-bridge.sh"
}

run_tools() {
  "$BASE_DIR/terminal/menus/mq-tools-menu.sh"
}

run_system() {
  if [[ "${1:-}" == "check" ]]; then
    "$BASE_DIR/tools/scripts/system-check.sh"
  else
    "$BASE_DIR/terminal/menus/mq-system-menu.sh"
  fi
}

run_demo() {
  if [[ -x "$BASE_DIR/tools/scripts/demo.sh" ]]; then
    "$BASE_DIR/tools/scripts/demo.sh"
  else
    echo "[MQ] Demo script not found."
    return 1
  fi
}

print_help() {
  cat <<'HELP'

Built-in
--------
help, h               Show help
clear, cls            Clear screen
exit, quit, x         Exit mqlaunch

Core workflows
--------------
doctor                Run doctor
perf                  Run performance workflow
dev                   Run dev workflow
tools                 Open tools workflow
demo                  Run demo
system                Open system workflow
system check          Run system check

Aliases
-------
d                     doctor
p                     perf
t                     tools
sys                   system
sc                    system check

Shell fallback
--------------
Unknown commands run in your shell.

Examples:
  ls -la
  pwd
  git status
  ls -la | grep README
  cat README.md > /tmp/readme.txt

HELP
}

normalize_aliases() {
  local line="$1"

  case "$line" in
    h)   echo "help" ;;
    d)   echo "doctor" ;;
    p)   echo "perf" ;;
    t)   echo "tools" ;;
    sys) echo "system" ;;
    sc)  echo "system check" ;;
    q|x) echo "exit" ;;
    *)   echo "$line" ;;
  esac
}

run_shell_fallback() {
  local line="$1"
  echo
  echo "[MQ] Running shell command: $line"
  echo
  "$MQ_SHELL" -lc "$line"
}

dispatch_command() {
  local line="$1"

  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"

  [[ -z "$line" ]] && return 0

  line="$(normalize_aliases "$line")"

  case "$line" in
    help)
      print_help
      return 0
      ;;
    clear|cls)
      clear
      return 0
      ;;
    exit|quit)
      return 99
      ;;
    doctor)
      run_doctor
      return $?
      ;;
    perf|performance)
      run_perf
      return $?
      ;;
    dev)
      run_dev
      return $?
      ;;
    tools)
      run_tools
      return $?
      ;;
    demo)
      run_demo
      return $?
      ;;
    "system check")
      run_system check
      return $?
      ;;
    system)
      run_system
      return $?
      ;;
  esac

  run_shell_fallback "$line"
  return $?
}

read_prompt_input() {
  local line

  # Draw UI directly to terminal, not stdout
  {
    printf '%s\n' "$MQ_LINE"
    printf '%s\n' "$PROMPT_LABEL"
    printf '%s\n' "$MQ_LINE"
    printf 'MQLAUNCH — Command Surface\n'
    printf 'help = commands · x = exit\n'
    # Move up to prompt row
    printf '\033[4A'
    # Move right to end of "mqlaunch > "
    printf '\033[%dC' "${#PROMPT_LABEL}"
  } > /dev/tty

  IFS= read -r line < /dev/tty

  # Move cursor to end of block after user pressed Enter
  {
    printf '\033[4B'
    printf '\r'
  } > /dev/tty

  REPLY="$line"
}

main() {
  local line status

  while true; do
    read_prompt_input
    line="$REPLY"
    echo

    dispatch_command "$line"
    status=$?

    if [[ $status -eq 99 ]]; then
      echo
      break
    elif [[ $status -ne 0 ]]; then
      echo
      echo "[MQ] Command failed with exit code: $status"
    fi

    echo
  done

  echo "[MQ] Bye."
}

main "$@"
